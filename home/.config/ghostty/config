# Ghostty - edit this file directly; it is symlinked to ~/.config/ghostty/config.
# Docs: https://ghostty.org/docs/config

# Font
font-family = Maple Mono NF
font-size = 15
# calt = ligatures
font-feature = calt

# Theme: follows system light/dark (Catppuccin, built in)
# NOTE: Ghostty theme names are the exact built-in filenames (Title Case, spaces).
theme = light:Catppuccin Latte,dark:Catppuccin Frappe

# Pastel translucency
background-opacity = 0.85
background-blur = true

# Window
window-padding-x = 12
window-padding-y = 12
window-padding-balance = true
window-save-state = always
macos-titlebar-style = tabs
# Alt works for word motions / readline. Ghostty has no inline comments,
# so keep notes like this on their own line - never after a value.
macos-option-as-alt = true

# Cursor
cursor-style = block
cursor-style-blink = false
mouse-hide-while-typing = true

# Behavior
copy-on-select = clipboard
scrollback-limit = 10000000
confirm-close-surface = false
shell-integration = zsh
shell-integration-features = cursor,sudo,title

# herdr owns panes / tabs / workspaces, so no split keybinds here on purpose -
# keeping Ghostty a thin, fast surface avoids clashing with herdr's chords.
keybind = cmd+enter=toggle_fullscreen
